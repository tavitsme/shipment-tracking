# ---------------------------------------------------------------------------
# Shipment Tracking System — environment template (PLACEHOLDERS ONLY).
#
# Copy this file to ".env" and fill in real values.
#   * NEVER commit ".env" — it is git-ignored.
#   * On the VPS this file lives at: /docker/tracking/.env
#
# Required at boot: DATABASE_URL and TRACKING_HASH_SALT (app throws otherwise).
# All carrier credentials are optional in the prototype — leave blank.
# ---------------------------------------------------------------------------

NODE_ENV=production
PORT=8080
BASE_PATH=/tracking

# PostgreSQL connection (used by the app to talk to the "postgres" service).
# On the VPS / in docker-compose the host is "postgres". For local dev outside
# compose, point this at localhost and the compose-exposed port (e.g. 5433).
DATABASE_URL=postgres://tracking_user:CHANGE_ME_PASSWORD@postgres:5432/tracking_db

# Long random string used to hash tracking numbers. NEVER commit a real value.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
TRACKING_HASH_SALT=CHANGE_ME_LONG_RANDOM_STRING

# PostgreSQL service settings (used by the "postgres" container in compose).
POSTGRES_USER=tracking_user
POSTGRES_PASSWORD=CHANGE_ME_PASSWORD
POSTGRES_DB=tracking_db

# Host port the compose postgres publishes on (host 5433 -> container 5432).
POSTGRES_PORT=5433

# --- Carrier credentials (all OPTIONAL / empty in the prototype) ------------
# Fill only when a carrier has been obtained. isConfigured() flips automatically.
THAILAND_POST_API_TOKEN=
DHL_API_KEY=
DHL_API_SECRET=
FEDEX_CLIENT_ID=
FEDEX_CLIENT_SECRET=
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
ARAMEX_USERNAME=
ARAMEX_PASSWORD=
ARAMEX_ACCOUNT_NUMBER=
ARAMEX_ACCOUNT_PIN=
SF_EXPRESS_CLIENT_CODE=
SF_EXPRESS_CHECKWORD=

# --- Traefik integration (VPS only) -----------------------------------------
# The EXTERNAL docker network that the existing Traefik (owned by the n8n
# project) lives on. The app joins this network so Traefik can route to it.
# DISCOVER the real name on the VPS before setting (see README -> Deploy):
#   docker network ls
#   docker inspect n8n-traefik-1 --format '{{json .NetworkSettings.Networks}}'
# Expected value: n8n_default
# Leave empty ONLY for local dev without Traefik (compose will then error,
# which is expected — use `docker compose up postgres` + `npm run dev` instead).
TRAEFIK_NETWORK=
